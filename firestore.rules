
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────
    function isAuthed() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthed() && userRole() == "admin";
    }

    function isEmployee() {
      return isAuthed() && userRole() == "employee";
    }

    function ownEmpId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.empId;
    }

    // ── /users ────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuthed() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // ── /employees ────────────────────────────────────────
    match /employees/{empId} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    // ── /departments ──────────────────────────────────────
    match /departments/{deptId} {
      allow read: if isAuthed();
      allow create, update, delete: if isAdmin();
    }

    // ── /leaveRequests ────────────────────────────────────
    match /leaveRequests/{reqId} {
      // Admins can do everything; employees can read their own and create new
      allow read: if isAdmin() || (isEmployee() && resource.data.empId == ownEmpId());
      allow create: if isEmployee() && request.resource.data.empId == ownEmpId();
      // Only admins can approve / reject
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── /attendance ───────────────────────────────────────
    match /attendance/{recordId} {
      allow read: if isAdmin() || (isEmployee() && resource.data.empId == ownEmpId());
    allow create, update, delete: if isAdmin();
      allow create, update: if isEmployee()
                             && request.resource.data.empId == ownEmpId();
    }

    // ── /media ────────────────────────────────────────────
    // FIX (Bug 2): Collection had no rules → Firestore denied all access.
    // Admins can do everything.
    // Employees can read all media and create new records (uploadedBy must
    // match their own empId to prevent spoofing).
    // Only admins can update or delete media records.
    match /media/{mediaId} {
      allow read: if isAuthed();
      allow create: if isEmployee() && request.resource.data.uploadedBy == ownEmpId();
      allow update, delete: if isAdmin();
    }
  }
}